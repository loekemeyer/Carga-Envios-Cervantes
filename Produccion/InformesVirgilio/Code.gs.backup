/**
 * Apps Script - dump JSON de Producción Virgilio + PPP Pedidos Entregados 2026
 * Protegido con token. Solo permite GET con ?token=XXX correcto.
 */

const PROD_ID  = '1xekWfCkhSfRNEwV7fX2JlhoX8NVYaLsaEfz7ovEo45g';
const PROD_HOJA = 'Hoja 1';
const OPER_HOJA = 'Operarios';

const PPP_ID   = '1-16YXe0xq6x9i-Yhk5cm5V3VqvQ0PWZtcDbm8OeeKW0';
const PPP_HOJA = 'PPP Excel Pedidos Entregados 2026';
const PPP_HOJA_PROG = 'PPP Excel Programacion Diaria';   // fallback Mt3 cuando no está en hoja principal

const API_TOKEN = 'VGjGk3F0jtix2jyFHPKxR1DObcLdIbde';

function doGet(e) {
  const token = (e && e.parameter && e.parameter.token) || '';
  if (token !== API_TOKEN) {
    return ContentService
      .createTextOutput(JSON.stringify({ error: 'unauthorized' }))
      .setMimeType(ContentService.MimeType.JSON);
  }
  const desde = (e.parameter.desde) || null;
  const hasta = (e.parameter.hasta) || null;
  const data = {
    produccion: leeProduccion(desde, hasta),
    ppp: leePpp(),
    pppProgDiaria: leePppProgDiaria(),
    operarios: leeOperarios(),
    debugProg: debugHojas(),
    meta: { generadoEn: new Date().toISOString(), filtro: { desde, hasta } }
  };
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

function leeProduccion(desde, hasta) {
  const sh = SpreadsheetApp.openById(PROD_ID).getSheetByName(PROD_HOJA);
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];
  const out = [];
  for (let i = 1; i < values.length; i++) {
    const r = values[i];
    if (!r[0]) continue;
    const fecha = formateaFechaCorta(r[0]);
    if (desde && fechaMenor(fecha, desde)) continue;
    if (hasta && fechaMayor(fecha, hasta)) continue;
    out.push({
      fecha: fecha,
      hora: formateaHora(r[1]),
      legajo: String(r[2] || '').trim(),
      opcion: String(r[3] || '').trim(),
      descripcion: String(r[4] || '').trim(),
      codigo: String(r[5] || '').trim()
    });
  }
  return out;
}

function leeOperarios() {
  const sh = SpreadsheetApp.openById(PROD_ID).getSheetByName(OPER_HOJA);
  if (!sh) return [];
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];
  // Detectar headers (Legajo, Nombre)
  const header = values[0].map(c => String(c||'').trim().toLowerCase());
  const cLeg = header.findIndex(h => h.includes('legajo'));
  const cNom = header.findIndex(h => h.includes('nombre') || h.includes('empleado'));
  if (cLeg === -1) return [];
  const out = [];
  for (let i = 1; i < values.length; i++) {
    const leg = String(values[i][cLeg] || '').trim();
    const nom = cNom >= 0 ? String(values[i][cNom] || '').trim() : '';
    if (!leg) continue;
    out.push({ legajo: leg, nombre: nom });
  }
  return out;
}

function debugHojas() {
  // Diagnóstico: lista todas las pestañas y primeras filas de la candidata "Prog Diaria"
  const ss = SpreadsheetApp.openById(PPP_ID);
  const hojas = ss.getSheets().map(h => h.getName());
  const candidata = hojas.find(n => /prog/i.test(n)) || null;
  let primerasFilas = null;
  if (candidata) {
    const sh = ss.getSheetByName(candidata);
    const rng = sh.getRange(1, 1, Math.min(8, sh.getLastRow()), Math.min(20, sh.getLastColumn()));
    primerasFilas = rng.getValues().map(row => row.map(c => String(c||'').trim()));
  }
  return { hojas, candidata, primerasFilas };
}

function leePppProgDiaria() {
  // Intenta leer la hoja "Programacion Diaria" (con o sin acento). Devuelve [] si no existe.
  const ss = SpreadsheetApp.openById(PPP_ID);
  let sh = ss.getSheetByName(PPP_HOJA_PROG)
        || ss.getSheetByName('PPP Excel Programación Diaria')
        || ss.getSheetByName('Programacion Diaria')
        || ss.getSheetByName('Programación Diaria');
  if (!sh) return [];
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];

  // Detectar header con "Tanda" (puede estar en cualquier fila)
  let headerRow = -1;
  let cols = {};
  for (let i = 0; i < values.length; i++) {
    const row = values[i].map(c => String(c || '').trim());
    if (row.indexOf('Tanda') !== -1) {
      headerRow = i;
      row.forEach((cell, idx) => { cols[cell] = idx; });
      break;
    }
  }
  if (headerRow === -1) return [];

  const cTanda  = cols['Tanda'];
  const cNP     = cols['N° NP'] || cols['Nº NP'] || cols['NP'];
  const cMt3    = cols['Mt3'];
  const cMt3Fc  = cols['Mt3 FC'];
  const cFEnt   = cols['Fecha de Entrega'] || cols['Fecha Entrega'];
  const cFFc    = cols['Fecha de Fc'] || cols['Fecha Fc'];
  const cRazon  = cols['Razon Social'] || cols['Razón Social'];

  const out = [];
  for (let i = headerRow + 1; i < values.length; i++) {
    const r = values[i];
    const tanda = String(r[cTanda] || '').trim();
    const razon = cRazon !== undefined ? String(r[cRazon] || '').trim() : '';
    const mt3fc = cMt3Fc !== undefined ? parseNumero(r[cMt3Fc]) : 0;
    const mt3   = cMt3   !== undefined ? parseNumero(r[cMt3])   : 0;
    if (!tanda && !razon) continue;
    out.push({
      tanda, razon,
      np: cNP !== undefined ? String(r[cNP] || '').trim() : '',
      mt3, mt3fc,
      fechaEntrega: cFEnt !== undefined ? formateaFechaCorta(r[cFEnt]) : '',
      fechaFc:      cFFc  !== undefined ? formateaFechaCorta(r[cFFc])  : ''
    });
  }
  return out;
}

function leePpp() {
  const sh = SpreadsheetApp.openById(PPP_ID).getSheetByName(PPP_HOJA);
  if (!sh) throw new Error('Hoja "' + PPP_HOJA + '" no encontrada en PPP');
  const values = sh.getDataRange().getValues();
  if (values.length < 2) return [];

  let headerRow = -1;
  let cols = {};
  for (let i = 0; i < values.length; i++) {
    const row = values[i].map(c => String(c || '').trim());
    if (row.indexOf('Tanda') !== -1) {
      headerRow = i;
      row.forEach((cell, idx) => { cols[cell] = idx; });
      break;
    }
  }
  if (headerRow === -1) return [];

  const cTanda  = cols['Tanda'];
  const cNP     = cols['N° NP'] || cols['Nº NP'] || 2;
  const cMt3    = cols['Mt3'];
  const cMt3Fc  = cols['Mt3 FC'];
  const cFEnt   = cols['Fecha de Entrega'];
  const cFFc    = cols['Fecha de Fc'];
  const cRazon  = cols['Razon Social'];

  const out = [];
  for (let i = headerRow + 1; i < values.length; i++) {
    const r = values[i];
    const tanda = String(r[cTanda] || '').trim();
    const razon = String(r[cRazon] || '').trim();
    const mt3fc = parseNumero(r[cMt3Fc]);
    const mt3   = parseNumero(r[cMt3]);
    if (!tanda && !razon) continue;
    out.push({
      tanda, razon,
      np: String(r[cNP] || '').trim(),
      mt3, mt3fc,
      fechaEntrega: formateaFechaCorta(r[cFEnt]),
      fechaFc:      formateaFechaCorta(r[cFFc])
    });
  }
  return out;
}

function formateaFechaCorta(v) {
  if (!v) return '';
  if (v instanceof Date) {
    const dd = String(v.getDate()).padStart(2, '0');
    const mm = String(v.getMonth() + 1).padStart(2, '0');
    return dd + '/' + mm + '/' + v.getFullYear();
  }
  return String(v).trim();
}
function formateaHora(v) {
  if (!v) return '';
  if (v instanceof Date) {
    return Utilities.formatDate(v, Session.getScriptTimeZone(), 'HH:mm:ss');
  }
  return String(v).trim();
}
function parseNumero(v) {
  if (v === '' || v === null || v === undefined) return 0;
  if (typeof v === 'number') return v;
  const s = String(v).replace(/\./g, '').replace(',', '.');
  const n = parseFloat(s);
  return isNaN(n) ? 0 : n;
}
function fechaMenor(a, b) { return parseDDMMYYYY(a) < parseDDMMYYYY(b); }
function fechaMayor(a, b) { return parseDDMMYYYY(a) > parseDDMMYYYY(b); }
function parseDDMMYYYY(s) {
  if (!s) return 0;
  const m = s.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  if (!m) return 0;
  return new Date(+m[3], +m[2]-1, +m[1]).getTime();
}
